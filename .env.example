# ============================================================
# PEDIA AI AGENT — Konfigurasi
# Salin file ini: cp .env.example .env
# Lalu edit: nano .env
# ============================================================

# ── Gemini AI ────────────────────────────────────────────────
# Dapatkan gratis di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Model Gemini yang digunakan (gratis & cepat):
# gemini-1.5-flash (default, cepat)
# gemini-1.5-pro   (lebih cerdas)
# gemini-2.0-flash (terbaru)
GEMINI_MODEL=gemini-1.5-flash

# ── Telegram Bot ─────────────────────────────────────────────
# Buat bot di @BotFather: https://t.me/BotFather
# Ketik /newbot, ikuti instruksi, copy token di sini
TELEGRAM_TOKEN=your-telegram-bot-token-here

# ── Security: User yang boleh pakai bot ──────────────────────
# Cari user ID kamu di: https://t.me/userinfobot
# Pisahkan dengan koma jika lebih dari satu: 123456789,987654321
# Kosongkan untuk allow semua (tidak disarankan jika bot public)
ALLOWED_USER_IDS=

# ── Agent Settings ────────────────────────────────────────────
# Nama agent (muncul di chat)
AGENT_NAME=Pedia

# ── Memory Settings ───────────────────────────────────────────
# Jumlah pesan terakhir yang diingat dalam 1 sesi
SHORT_TERM_LIMIT=20

# Maksimal fakta di long-term memory
MAX_LONG_TERM=200
