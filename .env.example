# ══════════════════════════════════════════
# PEDIA AI AGENT v3.0 — Konfigurasi
# cp .env.example .env  →  nano .env
# ══════════════════════════════════════════

# ── AI Providers (minimal satu) ──────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

CEREBRAS_API_KEY=your-cerebras-api-key-here
CEREBRAS_MODEL=llama3.1-8b

GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# ── Agent ─────────────────────────────────
AGENT_NAME=Pedia

# ── Dashboard ─────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
# Password untuk login ke dashboard
DASHBOARD_SECRET=ganti-password-ini

# ── Memory ────────────────────────────────
SHORT_TERM_LIMIT=30
MAX_LONG_TERM=200

# ── Timing ────────────────────────────────
TYPING_WPM=250
MIN_TYPING_MS=1000
MAX_TYPING_MS=15000
AI_TIMEOUT=25

# ── Android ───────────────────────────────
# Diisi otomatis oleh install.sh
# CHROME_PATH=/data/data/com.termux/files/usr/bin/chromium
