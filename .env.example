# ============================================================
# PEDIA AI AGENT v2.0 — Konfigurasi
# Salin: cp .env.example .env
# Edit: nano .env
# ============================================================

# ── AI Providers (isi minimal satu) ──────────────────────────

# Google Gemini (GRATIS, paling direkomendasikan)
# Daftar: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Cerebras (cepat, gratis tier ada)
# Daftar: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your-cerebras-api-key-here
CEREBRAS_MODEL=llama3.1-8b

# Groq (fallback, gratis)
# Daftar: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# ── Agent Settings ────────────────────────────────────────────
AGENT_NAME=Pedia

# ── Memory ────────────────────────────────────────────────────
SHORT_TERM_LIMIT=30
MAX_LONG_TERM=200

# ── Performance ──────────────────────────────────────────────
# Kecepatan typing simulasi (kata per menit)
TYPING_WPM=300
# Timeout request ke AI provider (detik)
AI_TIMEOUT=20

# ── Group defaults ────────────────────────────────────────────
# AI aktif di grup secara default (true/false)
GROUP_AI_ENABLED_DEFAULT=true

# ── Android ──────────────────────────────────────────────────
# Path chromium (diisi otomatis oleh install.sh)
# CHROME_PATH=/data/data/com.termux/files/usr/bin/chromium
